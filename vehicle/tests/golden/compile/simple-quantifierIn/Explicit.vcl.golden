@property;
empty : Tensor;
empty = True

@property;
double : Tensor;
double = True

@property;
forallForallIn : Tensor;
forallForallIn = forall x . ReduceAnd (x == [0.5, 1.0]) and True

@property;
forallInForall : forallT (f : Tensor -> Tensor) . Tensor;
forallInForall f = (forall y . ReduceOr (f [0.5, 1.0] != y)) and True